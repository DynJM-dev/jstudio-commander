{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Commander",
  "version": "0.1.0",
  "identifier": "studio.jstudio.commander",
  "build": {
    "beforeDevCommand": "pnpm --filter @jstudio-commander/frontend dev",
    "beforeBuildCommand": "pnpm -w build:prep",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Commander",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "externalBin": ["../../sidecar/bundle/sidecar-bin"],
    "resources": {
      "../../sidecar/bundle/dist": "sidecar/dist",
      "../../sidecar/bundle/node_modules": "sidecar/node_modules",
      "../../sidecar/bundle/package.json": "sidecar/package.json",
      "../../sidecar/bundle/resources/osc133-hook.sh": "resources/osc133-hook.sh"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Commander",
  "version": "0.1.0",
  "identifier": "studio.jstudio.commander",
  "build": {
    "beforeDevCommand": "pnpm --filter @jstudio-commander/frontend dev",
    "beforeBuildCommand": "pnpm --filter @jstudio-commander/frontend build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Commander",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null
    }
  },
  "plugins": {}
}

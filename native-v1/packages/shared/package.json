      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./session-types": {
      "types": "./dist/session-types.d.ts",
      "default": "./dist/session-types.js"
    },
    "./session-state": {
      "types": "./dist/session-state.d.ts",
      "default": "./dist/session-state.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"

{
  "name": "@jstudio-commander/db",
  "version": "0.1.0-n1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "default": "./dist/migrations/index.js"
    }
  },
  "files": [
    "dist",
    "src/migrations"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && cp -r src/migrations dist/ 2>/dev/null || true",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "drizzle:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@jstudio-commander/shared": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}

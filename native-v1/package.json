{
  "name": "@jstudio-commander/native-v1",
  "version": "0.1.0-n1",
  "private": true,
  "description": "JStudio Commander native v1 — Tauri shell + Node sidecar + React frontend",
  "packageManager": "pnpm@10.5.0",
  "type": "module",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "tauri:dev": "pnpm --filter @jstudio-commander/shell tauri dev",
    "tauri:build": "pnpm --filter @jstudio-commander/shell tauri build",
    "sidecar:dev": "pnpm --filter @jstudio-commander/sidecar dev",
    "frontend:dev": "pnpm --filter @jstudio-commander/frontend dev"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty",
      "esbuild",
      "@tailwindcss/oxide"
    ]
  }
}

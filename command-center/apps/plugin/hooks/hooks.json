{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/session-start",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/user-prompt-submit",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/pre-tool-use",
            "timeout": 30,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/post-tool-use",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/notification",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/stop",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/subagent-start",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/subagent-stop",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/task-created",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/task-completed",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/session-end",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/pre-compact",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COMMANDER_PORT}/hooks/post-compact",
            "timeout": 5,
            "headers": { "Authorization": "Bearer ${COMMANDER_TOKEN}" },
            "allowedEnvVars": ["COMMANDER_TOKEN", "COMMANDER_PORT"]
          }
        ]
      }
    ]
  }
}

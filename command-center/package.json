{
  "name": "@commander/root",
  "version": "0.1.0-n1",
  "private": true,
  "description": "JStudio Command-Center — Tauri v2 + Bun sidecar monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:sidecar": "bun --filter '@commander/sidecar' build:binary",
    "build:frontend": "bun --filter '@commander/frontend' build",
    "build:prep": "bun run build:sidecar && bun run build:frontend",
    "build:app": "bun run build:prep && bun --filter '@commander/shell' tauri:build",
    "build:app:debug": "bun run build:prep && bun --filter '@commander/shell' tauri:build:debug",
    "dev": "bun --filter '@commander/shell' tauri:dev",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "1.1.14",
    "typescript": "5.7.2"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}

{
  "name": "jstudio-commander",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel --filter @commander/server --filter @commander/client dev",
    "dev:server": "pnpm --filter @commander/server dev",
    "dev:client": "pnpm --filter @commander/client dev",
    "build": "pnpm --filter @commander/shared build && pnpm --filter @commander/client build && pnpm --filter @commander/server build",
    "start": "node server/dist/index.js",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "ws": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
